    "how_to_play_selector_stack_panel/how_to_play_selector_pane": {
        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_front",
                "value": [
                    {
                        "padding_00": {
                            "type": "panel",
                            "size": [
                                0,
                                6
                            ]
                        }
                    },
                    {
                        "heavy_machinery_category@how_to_play_common.topic_category": {
                            "$category": "heavy_machinery"
                        }
                    },
                    {
                        "hm:multiblock_overview_button@how_to_play.hm:multiblock_overview_button": {
                            "$toggle_group_forced_index": 351
                        }
                    },
                    {
                        "hm:crusher_build_button@how_to_play.hm:crusher_build_button": {
                            "$toggle_group_forced_index": 352
                        }
                    }
                ]
            }
        ]
    },
