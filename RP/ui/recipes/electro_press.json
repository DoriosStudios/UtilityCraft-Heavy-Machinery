{
  "namespace": "uc",
  "electro_press_recipes_buttons/addon_recipe_rows": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "hm_electro_press_rows@uc.hm_electro_press_recipe_rows": {}
          }
        ]
      }
    ]
  },
  "electro_press_recipes_panel/recipes_panel/addon_recipe_panels": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "hm_electro_press_panels@uc.hm_electro_press_recipe_panels": {}
          }
        ]
      }
    ]
  },
  "hm_electro_press_recipe_rows": {
    "type": "stack_panel",
    "size": [126, "100%c"],
    "orientation": "vertical",
    "controls": [
      {
        "hm_electro_press_separator@uc.addon_recipe_separator": {
          "$separator_label": "Heavy Machinery"
        }
      },
      {
        "hm_electro_press_recipe_row_0": {
          "type": "panel",
          "size": [126, 18],
          "controls": [
            {
              "hm_tin_plate_toggle@uc.electro_press_recipe_toggle": {
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "$toggle_index": 2000,
                "$toggle_hover_text": "item.utilitycraft:tin_plate",
                "$toggle_control_name": "hm_tin_plate_recipe",
                "$recipe_icon": "textures/items/tin_plate",
                "offset": [0, 0]
              }
            },
            {
              "hm_uranium_rod_toggle@uc.electro_press_recipe_toggle": {
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "$toggle_index": 2001,
                "$toggle_hover_text": "item.utilitycraft:uranium_rod",
                "$toggle_control_name": "hm_uranium_rod_recipe",
                "$recipe_icon": "textures/items/uranium_rod",
                "offset": [18, 0]
              }
            },
            {
              "hm_bronze_plate_toggle@uc.electro_press_recipe_toggle": {
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "$toggle_index": 2002,
                "$toggle_hover_text": "item.utilitycraft:bronze_plate",
                "$toggle_control_name": "hm_bronze_plate_recipe",
                "$recipe_icon": "textures/items/bronze_plate",
                "offset": [36, 0]
              }
            }
          ]
        }
      }
    ]
  },
  "hm_electro_press_recipe_panels": {
    "type": "panel",
    "anchor_from": "center",
    "anchor_to": "center",
    "size": [80, 108],
    "controls": [
      {
        "hm_tin_plate_panel@uc.recipe_panel": {
          "$recipe_control_name": "hm_tin_plate_recipe",
          "controls": [
            {
              "input@uc.electro_press_recipe_input": {
                "$slot_item_texture": "textures/items/tin_ingot",
                "$slot_hover_text": "item.utilitycraft:tin_ingot",
                "$has_slot_hover": true,
                "$slot_count_text": "1",
                "$has_slot_count": true
              }
            },
            {
              "output@uc.electro_press_recipe_output": {
                "$slot_item_texture": "textures/items/tin_plate",
                "$slot_hover_text": "item.utilitycraft:tin_plate",
                "$has_slot_hover": true
              }
            }
          ]
        }
      },
      {
        "hm_uranium_rod_panel@uc.recipe_panel": {
          "$recipe_control_name": "hm_uranium_rod_recipe",
          "controls": [
            {
              "input@uc.electro_press_recipe_input": {
                "$slot_item_texture": "textures/items/uranium_ingot",
                "$slot_hover_text": "item.utilitycraft:uranium_ingot",
                "$has_slot_hover": true,
                "$slot_count_text": "1",
                "$has_slot_count": true
              }
            },
            {
              "output@uc.electro_press_recipe_output": {
                "$slot_item_texture": "textures/items/uranium_rod",
                "$slot_hover_text": "item.utilitycraft:uranium_rod",
                "$has_slot_hover": true
              }
            }
          ]
        }
      },
      {
        "hm_bronze_plate_panel@uc.recipe_panel": {
          "$recipe_control_name": "hm_bronze_plate_recipe",
          "controls": [
            {
              "input@uc.electro_press_recipe_input": {
                "$slot_item_texture": "textures/items/bronze_ingot",
                "$slot_hover_text": "item.utilitycraft:bronze_ingot",
                "$has_slot_hover": true,
                "$slot_count_text": "1",
                "$has_slot_count": true
              }
            },
            {
              "output@uc.electro_press_recipe_output": {
                "$slot_item_texture": "textures/items/bronze_plate",
                "$slot_hover_text": "item.utilitycraft:bronze_plate",
                "$has_slot_hover": true
              }
            }
          ]
        }
      }
    ]
  }
}
