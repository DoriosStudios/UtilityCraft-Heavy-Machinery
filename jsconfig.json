{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "DoriosCore": ["types/DoriosCore/index.d.ts"],
      "DoriosCore/index.js": ["types/DoriosCore/index.d.ts"],
      "DoriosLib": ["BP/scripts/DoriosLib/index.js"],
      "DoriosLib/index.js": ["BP/scripts/DoriosLib/index.js"],
      "DoriosLib/*": ["BP/scripts/DoriosLib/*"],
      "@utilitycraft/core": ["BP/scripts/DoriosCore/index.js"],
      "@utilitycraft/core/*": ["BP/scripts/DoriosCore/*"],
      "@scripts/*": ["BP/scripts/*"]
    }
  },
  "include": ["BP/scripts/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "builds", "packs", "Renders"]
}
